-->8
-- player stuff

function check_mud(tile,player)
	if fget(tile,1) then
		if (not player) return true
		if spikeboots then
			return true
		else
			harm()
			return false
		end
	end
	if (bootstimer > 0 or not player) return fget(tile,2)
	return false
end

function collides_solid(x,y,spd,hor,player)
	local tile = get_map_tile(x,y)
	if (spd==0) return fget(tile,0) and not check_mud(tile,player)
	if (hor) x+=spd
	if (not hor) y+=spd
	
	return fget(tile,0) and not check_mud(tile,player)
end

function allow_move(x,y,spd,hor,player)
	if hor then
		x+=4*sgn(spd)
		y+=1
	else
		x+=1
		y+=4*sgn(spd)
	end
	if (collides_solid(x,y,spd,hor,player)) return false
	if (hor) y-=2
	if (not hor) x-=2
	if (collides_solid(x,y,spd,hor,player)) return false
	return true
end

function check_interact()
	--if (not pfup) return
	local tile = get_map_tile(px,py-7)
	if tile == 8 and key>0 then
		key -= 1
		set_map_tile(px,py-7,18)
	elseif tile == 40 and greenkey>0 then
		greenkey -= 1
		set_map_tile(px,py-7,18)
	elseif tile == 6 then
		local chest = chests["x"..mpos(px).."y"..mpos(py-7)]
		pbeholdi = chest.ico
		pbeholdt = 60
		chest:act()
		-- if (chest.mus>-1) music(chest.mus)
		if ((not chest.shapelock) or shape>=5) set_map_tile(px,py-7,22)
		return true
	end
	return false
end

function move_player()
	accel = 0.3 + (feather * 0.05)
	
	local phor = btn(⬅️) or btn(➡️)
	local pver = btn(⬆️) or btn(⬇️)
	
	if (phor) pfright = btn(➡️)
	-- originally checked pver
	-- but standing with back
	-- turned looks weird
	pfup = btn(⬆️)
	
	-- only the above check
 -- cares about horizontal
 -- or vertical
	pmoving = phor or pver
	
	if btn(🅾️) then
		if (not check_interact()) and boots and pmoving then
			if (bootstimer%6==0) sfx(13)
			bootstimer += 1
			if bootstimer >= 30 then
				accel *= 1.7
			else
				return
			end
		elseif bootstimer > 0 then
			bootstimer = 0
		end
	else
		if bootstimer > 0 then
			bootstimer = 0
		end
	end
	
	if pmoving then
		if (btn(⬅️)) pvx -= accel
		if (btn(➡️)) pvx += accel
		if (btn(⬆️)) pvy -= accel
		if (btn(⬇️)) pvy += accel
	else
		-- if player wants to stop,
		-- stop them faster
		-- (stack with later mult)
		pvx *= 0.5
		pvy *= 0.5
	end
	
	-- check if we should be
	-- allowed to move
	if (allow_move(px,py,pvx,true,true)) then
	 px += pvx
	else
	 pvx *= 0.5
	end
	if (allow_move(px,py,pvy,false,true)) then
	 py += pvy
	else
		pvy *= 0.5
	end
	
	-- friction to combat accel
	pvx *= 0.7
	pvy *= 0.7
end

function draw_player()
	if pbeholdt > 0 then
		spr(99,px-4,py-4)
		spr(pbeholdi,px-4,py-12)
		pbeholdt -= 1
		return
	end
	if (pinv % 2 == 1) return
	local plrspr = 96
	if (pfup) plrspr += 16
	
	if not pmoving then
		pframe = 1
		pfdir = 1
		pftimer = player_anim_speed
	end
	
	if pftimer<=0 then
		pframe += pfdir
		if (pframe==0) pfdir=1
		if (pframe==2) pfdir=-1
		pftimer = player_anim_speed
	else
		pftimer -= 1
		-- subtract twice when running. fast move
		if (bootstimer>0) pftimer -= 2
	end
	
	spr(plrspr+pframe,px-4,py-4,1,1,pfright)
	if pbubblemove>0 then
		spr(100,px-8,py-8,2,2)
	end
end
-->8
-- sword stuff

function set_sword_dir()
	if (btn(⬆️) and btn(➡️))
	or (btn(⬆️) and btn(⬅️))
	or (btn(⬇️) and btn(⬅️))
	or (btn(⬇️) and btn(➡️))
	then
		soff = 2
	elseif btn(⬆️) or btn(⬇️) then
		soff = 0
	else
		soff = 1
	end
	sflipx = not pfright
	sflipy = btn(⬇️)
end

function sword_collide(x,y,lvl,rad)
	for i,v in pairs(sword_hitbox_corners) do
		local targetx = x+(v.x*rad)
		local targety = y+(v.y*rad)
		local tile = get_map_tile(targetx,targety)
		if (tile==7 and lvl>0) set_map_tile(targetx,targety,18)
		if (tile==23 and lvl>=2) set_map_tile(targetx,targety,18)
		if tile==16 and sfire>0 then
		 set_map_tile(targetx,targety,32)
		 torch_lit(targetx,targety)
		end
	end
end

function draw_fireball()
	for i,v in pairs(fireball) do
		circfill(v.x,v.y,sfire,9)
	end
end

function move_fireball()
	for i,v in pairs(fireball) do
		v.x += v.vx
		v.y -= v.vy
		v.t -= 1
		sword_collide(v.x,v.y,1,sfire)
		
		if (v.t<=0) del(fireball,v)
	end
end

function make_fireball(fx,fy)
	if (not sfire) return
	if (#fireball>=2) return
	add(fireball,{x=px+sx,y=py+sy,vx=fx,vy=fy,t=30})
end

function get_sword_mults()
	local xmult = 2
	local ymult = 2
	if (sflipx) xmult *= -1
	if (sflipy) ymult *= -1
	if (soff == 1) ymult *= 0
	if (soff == 0) xmult *= 0
	return {x=xmult,y=ymult}
end

function update_sword()
	if stimer > 0 then
		local mult = get_sword_mults()
		if (stimer <= 8) then
			if (abs(sx) > 0 or abs(sy) > 0) then
				sx -= mult.x
				sy += mult.y
			end
		else
			if (abs(sx) < 8) and (abs(sy) < 8) then
				sx += mult.x
				sy -= mult.y
			end
		end
		
		sword_collide(px+sx,py+sy,stype,3)
		
		stimer -= 1
	elseif btnp(❎) then
		sx=0
		sy=0
	 if (stype>0) stimer=20
	 set_sword_dir()
	 if sfire>0 then
	 	local mult = get_sword_mults()
	 	make_fireball(mult.x,mult.y)
	 end
	 sfx(0)
	end
end

function draw_sword()
	if (sx==0 and sy==0) return
	spr(48+soff+(stype*16),px+sx-4,py+sy-4,1,1,sflipx,sflipy)
end
-->8
-- painful stuff

function harm()
	if pinv>0 then
		return
	end
	sfx(1)
	if temp_life > 0 then
		temp_life -= 1
	else
		life -= 1
	end
	pinv = 30
	if life == 0 then
		life = max_life
		px = 95*8
		py = 42*8
	end
end

function check_for_harm()
	if pinv>0 then
		pinv -= 1
		return
	end
	local tile = get_map_tile(px,py)
	if (fget(tile,1) and not spikeboots) harm()
end

function make_spinner(sx,sy,styp)
	add(spinners,{
		x=(sx*8)+4,
		y=(sy*8)+4,
		typ=styp,
		dir=1
	})
end

function draw_spinners()
	for i,v in pairs(spinners) do
		spr(83+v.typ,v.x-4,v.y-4)
	end
end

function move_spinners()
	for i,v in pairs(spinners) do
		local hor = v.typ == 0
		
		if v.typ == 2 then
			if (not v.ox) v.ox = v.x
			if (not v.oy) v.oy = v.y
			v.x = v.ox + cos(t())*15
			v.y = v.oy + sin(t())*15
		elseif allow_move(v.x,v.y,v.dir,hor,false) then
			if (hor) v.x += v.dir
			if (not hor) v.y += v.dir
		else
			v.dir *= -1
		end
		
		local cx = abs(px-v.x)
		local cy = abs(py-v.y)
		-- smaller hitbox feels
		-- more fair 
		if cx < 6 and cy < 6 then
		 harm()
		end
	end
end
-->8
-- misc stuff

function draw_hud()
	for i=1,life+temp_life do
		if (i>life) then
			spr(75,px-62+((i-1)*10),py-62)
		else
			spr(68,px-62+((i-1)*10),py-62)
		end
	end
	if shape>0 then
		spr(72,px-62,py-52)
		print(shape,px-52,py-50,7)
	end
	
	if (notifytime>0) then
	 print(notifytext,px-62,py+50,7)
	 notifytime -= 1
	end
	
	if (key>0) then
		spr(71,px+54,py-63)
	end
	if (greenkey>0) then
		spr(76,px+44,py-63)
	end
end

function mpos(i)
	return flr(i/8)
end

function get_map_tile(x,y)
	return mget(mpos(x),mpos(y))
end

function set_map_tile(x,y,val)
	mset(mpos(x),mpos(y),val)
end

function draw_title()
	cls(0)
	print("0.1.0C",0,0)
	print("isles of trials",34,40)
	print("made by chromanyan",28,48)
	print("player drawn by @twilightstarart",0,56)
	print("item jingles by newsoupvi",14,64)
	print("press 🅾️ to start",30,72)
end

function stay_sane()
	if (stype>2) stype=2
	if (sfire>4) sfire=4
	if (feather>20) feather=20
end

function torch_lit(x,y)
 for i,torch in pairs(torches) do
 	del(torch.required,"x"..mpos(x).."y"..mpos(y))
 	
 	if #torch.required==0 then
 	 torch:act()
 	 del(torches,torch)
 	end
 end
end

function draw_bubbles()
	if (not bubble) return
	for i,v in pairs(bubbles) do
		spr(100,v.x*8,v.y*8,2,2)
	end
end

function do_bubble_move()
	px+=pbvx
	py+=pbvy
	pbubblemove -= 1
end

function test_bubble_collide()
	if (pbubblemove>0) return
	if (not bubble) return
	for i,v in pairs(bubbles) do
		local cx = abs(px-((v.x+1)*8))
		local cy = abs(py-((v.y+1)*8))
		if cx < 8 and cy < 8 then
			px = (v.x+1)*8
			py = (v.y+1)*8
		 pbubblemove = v.dur
		 pbvx = v.sx
		 pbvy = v.sy
		end
	end
end

function notify(text)
	notifytext = text
	notifytime = 150
end

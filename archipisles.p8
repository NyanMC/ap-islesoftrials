locs = {
	["easiest chest"]=			{0, 2^0},
	["spike obstacle chest"]=		{0, 2^1},
	["torch puzzle chest"]=		{0, 2^2},
	["easy blade path chest"]=			{0, 2^3},
	["minor obstruction chest"]=			{0, 2^4},
	["blade squeeze chest"]=			{0, 2^5},
	["blade corridor chest"]=			{0, 2^6},
	["cheesable chest"]=			{0, 2^7},
	["rock shortcut chest"]=				{1, 2^0},
	["mud shortcut chest"]=				{1, 2^1},
	["spinner introduction chest"]=		{1, 2^2},
	["miniature forest chest"]=	{1, 2^3},
	["spike weave chest"]=			{1, 2^4},
	["spike path chest"]=			{1, 2^5},
	["dangerous torch puzzle chest"]=		{1, 2^6},
	["mud run chest"]=	{1, 2^7},
	["rock pile chest"]=			{2, 2^0},
	["spike gap chest"]=		{2, 2^1},
	["mud obstacle course chest"]=				{2, 2^2},
	["mud torch secret chest"]=				{3, 2^3},
	["rocky spinners chest"]=			{3, 2^4},
	["rocky torch secret chest"]=			{3, 2^5},
	["eye of the snake chest"]=			{3, 2^6},
	["gauntlet checkpoint chest"]=		{3, 2^7},
	["gauntlet chest"]=				{4, 2^0},
	["victory"]=			{4, 2^1},
}
items = {
	["progressive weapon"]=			{5, 2^0}, 
	["progressive weapon (alt)"]=			{5, 2^1}, 
	["fireball spell"]=			{5, 2^2}, 
	["sprinting boots"]=		{5, 2^3}, 
	["spike boots"]=				{5, 2^4}, 
	["bubbles"]=			{5, 2^5}, 
	["yellow key"]=			{5, 2^6}, 
	["green key"]=			{5, 2^7}, 
	["heart container 1"]=				{6, 2^0}, 
	["heart container 2"]=					{6, 2^1},
	["heart container 3"]=					{6, 2^2},
	["swift feather 1"]=					{6, 2^3},
	["swift feather 2"]=					{6, 2^4},
	["swift feather 3"]=					{6, 2^5},
}

function check_location(id)
	gpio_adr = 0x5f80 + locs[id][1]
	bank = peek(gpio_adr)
	bank = bank | locs[id][2]
	poke(gpio_adr, bank)
	
	notify("checked "..id)
end

function give_items()
	for key,item in pairs(items) do

		--item = items[key]
		gpio_adr = 0x5f80 + item[1]
		bank = peek(gpio_adr)
		if (bank & item[2]) ~= 0 then
			give_vanilla_item(key)
			items[key] = nil
			--remove the item so we cannot recieve it again
		end
	end
end

function give_vanilla_item(typ)
	if typ == "progressive weapon" or typ == "progressive weapon (alt)" then
		stype += 1
	end
	if typ == "fireball spell" then
		sfire += 1
	end
	if typ == "sprinting boots" then
		boots = true
	end
	if typ == "spike boots" then
		spikeboots = true
	end
	if typ == "bubbles" then
		bubble = true
	end
	if typ == "yellow key" then
		key += 1
	end
	if typ == "green key" then
		greenkey += 1
	end
	if typ == "heart container 1" or typ == "heart container 2" or typ == "heart container 3" then
		max_life += 1
		life = max_life
	end
	if typ == "swift feather 1" or typ == "swift feather 2" or typ == "swift feather 3" then
		feather += 1
	end
end

function ap_jingle()
	local jingle = peek(0x5f80+35)
	
	if jingle > 0 then
		music(jingle-1)
		poke(0x5f80+35,0)
	end
end
-->8
-- base p8 functions

function _init()
	for x=0,127 do
		for y=0,63 do
			if (mget(x,y) == 83) then
				make_spinner(x,y,0)
				mset(x,y,25)
			elseif (mget(x,y) == 84) then
				make_spinner(x,y,1)
				mset(x,y,25)
			elseif (mget(x,y) == 85) then
				make_spinner(x,y,2)
				mset(x,y,25)
			end
		end
	end
	--give_it_all()
end

function _draw()
	pal(1,140,1)
	
	if title then
		draw_title()
		return
	end
	
	cls(1)
	camera(px-64,py-64)
	map()
	
	draw_spinners()
	draw_fireball()
	draw_sword()
	draw_player()
	if (pbubblemove==0) draw_bubbles()
	draw_hud()
end

function _update()
	stay_sane()
	if title then
		if btnp(🅾️) then
			title = false
		end
	 return
	end
	
	ap_jingle()

	if (pbeholdt>0) return
	
	if pbubblemove>0 then
		do_bubble_move()
		return
	end
	
	move_player()
	move_fireball()
	move_spinners()
	if (stype>0 or sfire>0) update_sword()
	check_for_harm()
	test_bubble_collide()
	
	give_items()
end
